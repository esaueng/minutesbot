{
  "$schema": "./node_modules/wrangler/config-schema.json",
  // Self-hosting: replace every <PLACEHOLDER> below (or run `pnpm setup:cloudflare`,
  // which creates the resources and patches the ids/domains in place).
  // The Cloudflare account is selected via the CLOUDFLARE_ACCOUNT_ID env var
  // or `wrangler login`; account ids are intentionally not checked in.
  "name": "minutesbot",
  "main": "apps/api-worker/src/index.ts",
  "assets": {
    "directory": "./apps/web/dist",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
    "run_worker_first": true
  },
  "workers_dev": false,
  "routes": [
    {
      "pattern": "app.example.com",
      "custom_domain": true
    },
    {
      "pattern": "api.example.com",
      "custom_domain": true
    },
    {
      "pattern": "meeting.example.com",
      "custom_domain": true
    }
  ],
  "compatibility_date": "2026-05-04",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1
  },
  "vars": {
    "APP_BASE_URL": "https://app.example.com",
    "API_BASE_URL": "https://api.example.com",
    "BOT_WEBHOOK_BASE_URL": "https://meeting.example.com",
    "BOT_API_BASE_URL": "https://meeting-api.example.com",
    "DEFAULT_RECORDER_EMAIL": "notetaker@example.com",
    "DEFAULT_SENDER_EMAIL": "notetaker@example.com",
    "ENVIRONMENT": "production",
    "ALLOW_ADMIN_TOKEN_AUTH": "false"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "minutesbot",
      "database_id": "<D1_DATABASE_ID>"
    }
  ],
  "r2_buckets": [
    {
      "binding": "ARTIFACTS",
      "bucket_name": "minutesbot-artifacts"
    }
  ],
  "queues": {
    "producers": [
      {
        "binding": "JOBS_QUEUE",
        "queue": "minutesbot-jobs"
      }
    ],
    "consumers": [
      {
        "queue": "minutesbot-jobs",
        "max_batch_size": 10,
        "max_batch_timeout": 5,
        "max_retries": 5,
        "dead_letter_queue": "minutesbot-dlq"
      }
    ]
  },
  "triggers": {
    // Per-minute: durable job sweep + stale bot session recovery.
    // Daily 03:00 UTC: recurrence window expansion + retention cleanup.
    "crons": [
      "* * * * *",
      "0 3 * * *"
    ]
  },
  "send_email": [
    {
      "name": "SEND_EMAIL",
      "allowed_sender_addresses": [
        "notetaker@example.com"
      ]
    }
  ]
}
